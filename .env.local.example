# Sanity — required for CMS content (fallback data is used if empty)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity — optional, server-side only, required for on-demand revalidation / mutations
SANITY_API_TOKEN=

# GitHub — optional, increases API rate limit for project stats (commits, branches, LOC)
# Create a fine-grained token with public repo read access: https://github.com/settings/tokens
GITHUB_TOKEN=
